# ═══════════════════════════════════════════════════════════════
# Smart Claims Processor - Environment Configuration
# Copy this file to .env and fill in your values
# ═══════════════════════════════════════════════════════════════

# ── Required ──────────────────────────────────────────────────
# Get free key at: https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=your_gemini_api_key_here

# ── LLM Overrides (optional) ─────────────────────────────────
# LLM_MODEL=gemini-2.0-flash
# LLM_TEMPERATURE=0.1

# ── HITL Thresholds (optional) ────────────────────────────────
# HITL_MIN_AMOUNT=10000          # Claims >= $10K require human review
# HITL_FRAUD_THRESHOLD=0.65      # Fraud score >= 0.65 triggers HITL
# HITL_LOW_CONFIDENCE=0.65       # Agent confidence < 0.65 triggers HITL

# ── Budget Guards (optional) ──────────────────────────────────
# MAX_TOKENS_PER_CLAIM=50000
# MAX_COST_PER_CLAIM=0.50
# MAX_AGENT_CALLS=25

# ── Security (optional) ───────────────────────────────────────
# AUDIT_LOG_PATH=./data/audit_logs/
# PII_MASKING_ENABLED=true
