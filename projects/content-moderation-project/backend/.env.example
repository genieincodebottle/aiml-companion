# Required - Get a free key from https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=your_google_gemini_api_key_here

# Fast Mode - single-pass moderation for short comments (skip full 6-agent pipeline)
ENABLE_FAST_MODE=true
FAST_MODE_MAX_LENGTH=200
FAST_MODE_CONTENT_TYPES=story_comment

# ML Models - set to true for hybrid ML+LLM toxicity detection
# Downloads ~500MB of model files on first run (HateBERT/DistilBERT)
USE_ML_MODELS=false
ML_PRIMARY_MODEL=distilbert_toxic
ML_USE_ENSEMBLE=false
ML_PRELOAD_MODELS=true
ML_DEVICE=auto
