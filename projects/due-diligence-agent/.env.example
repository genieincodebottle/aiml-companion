# Required: Google Gemini API Key (free at https://aistudio.google.com/apikey)
GOOGLE_API_KEY=your_google_api_key_here

# Optional: Tavily Search API Key (free at https://tavily.com - 1000 searches/month)
# Falls back to DuckDuckGo if not set
TAVILY_API_KEY=your_tavily_api_key_here

# Optional: Override default model
# DD_MODEL_PROVIDER=google
# DD_MODEL_NAME=gemini-2.5-flash
# DD_MAX_COST_USD=0.50
# DD_LOG_LEVEL=INFO
