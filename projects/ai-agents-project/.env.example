# Required API keys for the Multi-Agent Research System
# Copy this file to .env and fill in your keys
#
# BOTH KEYS ARE COMPLETELY FREE - No credit card, no payment, no trial period.
# Getting both keys takes about 2 minutes.

# Google Gemini API key (required for agents + evaluation)
# FREE - Sign in with any Google account, click "Create API key"
# Get yours at: https://aistudio.google.com/apikey
# Free tier: 30 requests/minute, 1500 requests/day (more than enough for this project)
GOOGLE_API_KEY=your-google-api-key-here

# Tavily API key (required for web search tool)
# FREE - Sign up with email or GitHub, key appears on dashboard
# Get yours at: https://app.tavily.com/home
# Free tier: 1000 searches/month
TAVILY_API_KEY=your-tavily-api-key-here
